{
  "title": "Performance & System Metrics",
  "tags": ["performance", "system"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 27,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/sec)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ticketing_http_requests_total[5m]))",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "P95 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ticketing_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ticketing_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ticketing_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(ticketing_http_requests_total[5m])) * 100",
          "legendFormat": "5xx Errors",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 4,
      "title": "Goroutines",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ticketing_goroutines",
          "legendFormat": "Goroutines",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    },
    {
      "id": 5,
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ticketing_memory_usage_bytes / 1024 / 1024",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "id": 6,
      "title": "DB Connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ticketing_db_connections{state=\"in_use\"}",
          "legendFormat": "In Use",
          "refId": "A"
        },
        {
          "expr": "ticketing_db_connections{state=\"idle\"}",
          "legendFormat": "Idle",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
    }
  ]
}
