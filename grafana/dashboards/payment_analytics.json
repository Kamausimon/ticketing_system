{
  "title": "Payment Analytics Dashboard",
  "tags": ["payments", "finance"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 27,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Payment Success Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(ticketing_payment_success_total[1h])) / sum(increase(ticketing_payment_attempts_total[1h])) * 100",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 2,
      "title": "Payment Failures (Last Hour)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(ticketing_payment_failures_total[1h]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "id": 3,
      "title": "Total Transactions (Today)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(ticketing_payment_attempts_total[1d]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "id": 4,
      "title": "Avg Payment Duration",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg(rate(ticketing_payment_duration_seconds_sum[5m]) / rate(ticketing_payment_duration_seconds_count[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "title": "Payment Success vs Failures",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ticketing_payment_success_total[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ticketing_payment_failures_total[5m]))",
          "legendFormat": "Failures",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "id": 6,
      "title": "Orders by Payment Method",
      "type": "piechart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (payment_method) (increase(ticketing_orders_completed_total[1h]))",
          "legendFormat": "{{payment_method}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "id": 7,
      "title": "Refunds Issued",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ticketing_refunds_total[5m])) * 3600",
          "legendFormat": "Refunds per Hour",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
    },
    {
      "id": 8,
      "title": "Platform Fees Collected",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ticketing_platform_fees_total{currency=\"USD\"}[5m])) * 3600",
          "legendFormat": "Fees per Hour (USD)",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    }
  ]
}
