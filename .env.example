# Application Configuration
APP_NAME=Ticketing System
APP_ENV=development
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=ticketing_system
DB_SSL_MODE=disable

# ============================================
# Email Configuration (Using Go's Built-in SMTP)
# ============================================
# The system uses Go's standard net/smtp package
# Works with ANY SMTP server - no third-party dependencies!

# Choose ONE of the configurations below:

# Option 1: Gmail (Recommended for quick start)
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Ticketing System
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30
EMAIL_MAX_RETRIES=3
EMAIL_TEST_MODE=false

# Option 2: Outlook/Hotmail
# EMAIL_PROVIDER=outlook
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your-email@outlook.com
# EMAIL_PASSWORD=your-password
# EMAIL_FROM=your-email@outlook.com
# EMAIL_FROM_NAME=Ticketing System
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false

# Option 3: Mailtrap (Testing only - catches all emails)
# Sign up at https://mailtrap.io
# EMAIL_PROVIDER=mailtrap
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=587
# EMAIL_USERNAME=your_mailtrap_username
# EMAIL_PASSWORD=your_mailtrap_password
# EMAIL_FROM=test@example.com
# EMAIL_FROM_NAME=Test Sender
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false

# Option 4: Zoho Mail (Professional)
# EMAIL_PROVIDER=zoho
# EMAIL_HOST=smtp.zoho.com
# EMAIL_PORT=465
# EMAIL_USERNAME=noreply@yourdomain.com
# EMAIL_PASSWORD=your_zoho_app_password
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Ticketing System
# EMAIL_USE_TLS=false
# EMAIL_USE_SSL=true

# Option 5: SendGrid
# EMAIL_PROVIDER=sendgrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USERNAME=apikey
# EMAIL_PASSWORD=your_sendgrid_api_key
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_USE_TLS=true

# Option 6: Amazon SES
# EMAIL_PROVIDER=ses
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your_ses_smtp_username
# EMAIL_PASSWORD=your_ses_smtp_password
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_USE_TLS=true

# Option 7: Custom/Local SMTP Server (No authentication)
# Perfect for local development
# EMAIL_PROVIDER=local
# EMAIL_HOST=localhost
# EMAIL_PORT=25
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# EMAIL_FROM=noreply@localhost
# EMAIL_FROM_NAME=Local Development
# EMAIL_USE_TLS=false
# EMAIL_USE_SSL=false

# Option 8: Any other SMTP server
# EMAIL_PROVIDER=custom
# EMAIL_HOST=mail.yourserver.com
# EMAIL_PORT=587
# EMAIL_USERNAME=smtp_user
# EMAIL_PASSWORD=smtp_pass
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_USE_TLS=true

# Payment Configuration (IntaSend)
INTASEND_PUBLISHABLE_KEY=your_publishable_key
INTASEND_SECRET_KEY=your_secret_key
INTASEND_WEBHOOK_SECRET=your_webhook_secret
INTASEND_TEST_MODE=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRY=24h

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
